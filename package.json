{
  "name": "nest-kafka-standalone-worker-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone NestJS Kafka worker demo with ownership, ack, retry, and stress test",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "worker": "tsx watch src/worker/runner.ts",
    "simulate:produce": "tsx src/simulator/load-generator.ts",
    "report:consumers": "tsx src/simulator/consumer-report.ts",
    "stress": "tsx src/simulator/stress-runner.ts",
    "worker:1": "npm run worker -- worker-1",
    "worker:2": "npm run worker -- worker-2",
    "worker:3": "npm run worker -- worker-3"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/core": "^10.4.2",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
